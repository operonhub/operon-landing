# ── Envío de consultas del formulario (Resend) ──────────────────────────────
# 1. Creá una cuenta en https://resend.com
# 2. Generá una API key en https://resend.com/api-keys
# 3. Pegala acá (local) y en Vercel → Settings → Environment Variables
RESEND_API_KEY=

# Destino de las consultas. Por defecto: admin@operonhub.com
CONTACT_TO=admin@operonhub.com

# Remitente. Hasta verificar el dominio en Resend, dejá el sandbox
# (onboarding@resend.dev solo entrega al dueño de la cuenta).
# Una vez verificado operonhub.com en https://resend.com/domains, cambiá a:
# CONTACT_FROM="Operon <noreply@operonhub.com>"
CONTACT_FROM="Operon <onboarding@resend.dev>"
